# Django
SECRET_KEY=replace-with-a-real-strong-production-secret-key
DEBUG=False
ALLOWED_HOSTS=your-backend-domain.onrender.com,your-custom-domain.com

# Database
# Use the real PostgreSQL DATABASE_URL from Render/Railway/AWS
# Example format:
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Frontend / CORS
FRONTEND_URL=https://your-frontend-domain.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.vercel.app

# Google Login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI
AI_PROVIDER=gemini
GEMINI_API_KEY=your-production-gemini-key
OPENAI_API_KEY=your-production-openai-key

# JWT
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True